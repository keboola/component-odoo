{
  "type": "object",
  "title": "Odoo Extractor Configuration",
  "required": [
    "odoo_url"
  ],
  "properties": {
    "odoo_url": {
      "type": "string",
      "title": "Odoo URL",
      "description": "Your Odoo instance URL (e.g., https://mycompany.odoo.com or http://localhost:8069)",
      "propertyOrder": 10
    },
    "database": {
      "type": "string",
      "title": "Database Name",
      "description": "Odoo database name",
      "propertyOrder": 20,
      "enum": [],
      "options": {
        "async": {
          "action": "listDatabases",
          "label": "Load Databases"
        }
      }
    },
    "api_protocol": {
      "type": "string",
      "format": "radio",
      "title": "API Protocol",
      "enum": [
        "json2",
        "xmlrpc"
      ],
      "default": "xmlrpc",
      "propertyOrder": 25,
      "options": {
        "enum_titles": [
          "JSON-2",
          "XML-RPC"
        ],
        "tooltip": "Select JSON-2 for Odoo 19+ (recommended). XML-RPC is deprecated in Odoo 19 and will be removed in Odoo 20, but works with all older versions."
      }
    },
    "username": {
      "type": "string",
      "title": "Username",
      "description": "Required for XML-RPC",
      "propertyOrder": 30,
      "options": {
        "dependencies": {
          "api_protocol": "xmlrpc"
        }
      }
    },
    "#api_key": {
      "type": "string",
      "format": "password",
      "title": "API Key",
      "description": "Generate in user preferences",
      "propertyOrder": 40
    },
    "test_connection": {
      "type": "button",
      "format": "test-connection",
      "propertyOrder": 50,
      "options": {
        "async": {
          "action": "testConnection",
          "label": "Test Connection"
        }
      }
    },
    "endpoints": {
      "type": "array",
      "title": "Data Endpoints",
      "description": "Configure which Odoo models to extract",
      "propertyOrder": 100,
      "minItems": 1,
      "items": {
        "type": "object",
        "title": "Endpoint",
        "required": [
          "model"
        ],
        "properties": {
          "model": {
            "type": "string",
            "title": "Odoo Model",
            "description": "Odoo model name (e.g., res.partner, sale.order)",
            "propertyOrder": 10,
            "enum": [],
            "options": {
              "async": {
                "action": "listModels",
                "label": "Load Models"
              }
            }
          },
          "fields": {
            "type": "array",
            "format": "select",
            "title": "Fields to Extract",
            "description": "Select specific fields to extract, or leave empty to extract all available fields",
            "propertyOrder": 20,
            "enum": [],
            "items": {
              "type": "string"
            },
            "uniqueItems": true,
            "options": {
              "async": {
                "action": "listFields",
                "label": "Load Fields",
                "watchFor": [
                  "model"
                ]
              },
              "tags": true,
              "creatable": true
            }
          },
          "incremental": {
            "type": "boolean",
            "title": "Incremental Loading",
            "description": "Extract only new records since last run (based on ID field)",
            "default": false,
            "propertyOrder": 40
          },
          "limit": {
            "type": "integer",
            "title": "Record Limit",
            "description": "Maximum number of records to extract per run (0 = no limit)",
            "default": 1000,
            "minimum": 0,
            "maximum": 100000,
            "propertyOrder": 50
          },
          "order": {
            "type": "string",
            "title": "Sort Order",
            "description": "Order records by field (e.g., 'id asc', 'create_date desc')",
            "default": "id asc",
            "propertyOrder": 60
          }
        }
      }
    },
    "debug": {
      "type": "boolean",
      "title": "Debug Mode",
      "description": "Enable verbose logging for troubleshooting",
      "default": false,
      "propertyOrder": 200
    }
  }
}