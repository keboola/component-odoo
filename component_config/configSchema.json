{
  "type": "object",
  "title": "Odoo Extractor Configuration",
  "required": [
    "odoo_url",
    "database",
    "username",
    "#api_key",
    "endpoints"
  ],
  "properties": {
    "odoo_url": {
      "type": "string",
      "title": "Odoo URL",
      "description": "Your Odoo instance URL (e.g., https://mycompany.odoo.com or http://localhost:8069)",
      "propertyOrder": 10
    },
    "database": {
      "type": "string",
      "title": "Database Name",
      "description": "Odoo database name",
      "propertyOrder": 20
    },
    "username": {
      "type": "string",
      "title": "Username",
      "description": "Odoo user email or login",
      "propertyOrder": 30
    },
    "#api_key": {
      "type": "string",
      "title": "API Key / Password",
      "description": "Odoo API key or password",
      "format": "password",
      "propertyOrder": 40
    },
    "api_protocol": {
      "type": "string",
      "title": "API Protocol",
      "description": "Select XML-RPC (all versions) or JSON-2 (Odoo 19+). Use Test Connection to see which protocols your instance supports.",
      "enum": ["xmlrpc", "json2"],
      "default": "xmlrpc",
      "propertyOrder": 45,
      "options": {
        "enum_titles": [
          "XML-RPC (all versions, deprecated in Odoo 20)",
          "JSON-2 (Odoo 19+ only)"
        ]
      }
    },
    "test_connection": {
      "type": "button",
      "format": "test-connection",
      "propertyOrder": 50,
      "options": {
        "async": {
          "action": "testConnection",
          "label": "Test Connection"
        }
      }
    },
    "endpoints": {
      "type": "array",
      "title": "Data Endpoints",
      "description": "Configure which Odoo models to extract",
      "propertyOrder": 100,
      "minItems": 1,
      "items": {
        "type": "object",
        "title": "Endpoint",
        "required": [
          "model"
        ],
        "properties": {
          "model": {
            "type": "string",
            "title": "Odoo Model",
            "description": "Odoo model name (e.g., res.partner, sale.order)",
            "propertyOrder": 10,
            "enum": [],
            "options": {
              "async": {
                "action": "listModels",
                "label": "Load Models"
              }
            }
          },
          "fields": {
            "type": "array",
            "format": "select",
            "title": "Fields to Extract",
            "description": "Fields to extract from the model",
            "propertyOrder": 20,
            "enum": [],
            "items": {
              "type": "string"
            },
            "uniqueItems": true,
            "options": {
              "async": {
                "action": "listFields",
                "label": "Load Fields",
                "watchFor": [
                  "model"
                ]
              },
              "tags": true,
              "creatable": true
            }
          },
          "incremental": {
            "type": "boolean",
            "title": "Incremental Loading",
            "description": "Extract only new records since last run (based on ID field)",
            "default": false,
            "propertyOrder": 40
          },
          "limit": {
            "type": "integer",
            "title": "Record Limit",
            "description": "Maximum number of records to extract per run (0 = no limit)",
            "default": 1000,
            "minimum": 0,
            "maximum": 100000,
            "propertyOrder": 50
          },
          "order": {
            "type": "string",
            "title": "Sort Order",
            "description": "Order records by field (e.g., 'id asc', 'create_date desc')",
            "default": "id asc",
            "propertyOrder": 60
          }
        }
      }
    },
    "debug": {
      "type": "boolean",
      "title": "Debug Mode",
      "description": "Enable verbose logging for troubleshooting",
      "default": false,
      "propertyOrder": 200
    }
  }
}